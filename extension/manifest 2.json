{
  "manifest_version": 3,
  "name": "Flow2API Captcha Worker",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["https://labs.google/*"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
